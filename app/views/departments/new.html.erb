<h1>Create a New Department</h1>

<%= form_with(model: @department, local: true) do |form| %>
  <% if @department.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@department.errors.count, "error") %> prohibited this department from being saved:</h2>
      <ul>
        <% @department.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name %>
    <%= form.text_field :name, placeholder: "Enter department name" %>
  </div>

  <div>
    <%= form.label :description %>
    <%= form.text_area :description, placeholder: "Enter department description" %>
  </div>

  <div>
    <%= form.submit "Create Department" %>
  </div>
<% end %>

<%= link_to 'Back to Departments', departments_path %>
